---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Página de login con Google OAuth vía Supabase
// Redirige a /dashboard tras login exitoso
---

<Layout
  title="Iniciar Sesión — WallaBot"
  description="Accede a tu panel de WallaBot. Inicia sesión con Google para gestionar tu suscripción y configuración."
  canonicalURL="https://wallabot.pro/login"
>
  <Navbar />

  <main class="pt-24 pb-16 sm:pt-32 sm:pb-24">
    <div class="max-w-sm mx-auto px-4 sm:px-0">
      <!-- Card de login -->
      <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
        <div class="text-center mb-6">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-green-100 text-green-600 mb-4">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <rect width="28" height="28" rx="7" fill="#121212"/>
              <path d="M7 14.5h3.2l1.8-5.5 3.2 10 2.1-4.5H21" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h1 class="text-2xl font-extrabold text-gray-900">Iniciar sesión</h1>
          <p class="mt-2 text-sm text-gray-600">Accede a tu panel de WallaBot</p>
        </div>

        <!-- Google OAuth Button -->
        <button
          id="btnGoogleLogin"
          class="w-full flex items-center justify-center gap-3 px-4 py-3 bg-white border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-all cursor-pointer text-sm"
        >
          <svg width="20" height="20" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            <path fill="none" d="M1 1h22v22H1z"/>
          </svg>
          Continuar con Google
        </button>

        <p class="mt-4 text-xs text-center text-gray-400">
          Al iniciar sesión aceptas nuestros <a href="/terms" class="text-green-600 hover:underline">Términos</a> y <a href="/privacy" class="text-green-600 hover:underline">Privacidad</a>.
        </p>
      </div>

      <!-- Registro -->
      <p class="mt-6 text-center text-sm text-gray-500">
        ¿No tienes cuenta? <a href="/#precios" class="text-green-600 hover:underline font-semibold">Suscríbete a Premium</a>
      </p>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const SUPABASE_URL = 'https://dqvukbetvrfsjieqmnbq.supabase.co';
  const SUPABASE_ANON_KEY = 'sb_publishable_1lzZmrmw7IPdqvXkSxiQ3A_8w2ulCcW';

  // Inicializar Supabase client desde CDN
  const supabaseScript = document.createElement('script');
  supabaseScript.src = 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js';
  supabaseScript.onload = () => {
    const supabase = (window as any).supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    document.getElementById('btnGoogleLogin')?.addEventListener('click', async () => {
      const { error } = await supabase.auth.signInWithOAuth({
        provider: 'google',
        options: {
          redirectTo: `${window.location.origin}/dashboard`,
        },
      });

      if (error) {
        console.error('Error al iniciar sesión:', error.message);
        alert('Error al iniciar sesión con Google. Inténtalo de nuevo.');
      }
    });
  };
  document.head.appendChild(supabaseScript);
</script>
