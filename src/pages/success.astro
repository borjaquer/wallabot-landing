---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="¡Gracias por tu compra! — WallaBot"
  description="Tu suscripción a WallaBot Premium está activa. Sigue estos pasos para instalar la extensión y empezar a vender más."
  canonicalURL="https://wallabot.pro/success"
>
  <Navbar />

  <main class="pt-24 pb-16 sm:pt-32 sm:pb-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Icono de éxito -->
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 text-green-600 mb-6">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 tracking-tight">
        ¡Gracias por tu compra!
      </h1>
      <p class="mt-4 text-lg text-gray-600 max-w-xl mx-auto">
        Tu suscripción a <strong>WallaBot Premium</strong> está activa. Ahora solo te queda instalar la extensión y empezar a vender más.
      </p>

      <!-- Pasos de instalación -->
      <div class="mt-12 grid sm:grid-cols-3 gap-6 text-left">
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <div class="w-10 h-10 rounded-xl bg-green-600 text-white flex items-center justify-center font-bold text-lg mb-4">1</div>
          <h3 class="font-bold text-gray-900 mb-2">Descarga la extensión</h3>
          <p class="text-sm text-gray-600">Haz clic en el botón de abajo para descargar el archivo <code class="bg-gray-200 px-1.5 py-0.5 rounded text-xs">.crx</code> de WallaBot.</p>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <div class="w-10 h-10 rounded-xl bg-green-600 text-white flex items-center justify-center font-bold text-lg mb-4">2</div>
          <h3 class="font-bold text-gray-900 mb-2">Instala en Chrome</h3>
          <p class="text-sm text-gray-600">
            Abre <code class="bg-gray-200 px-1.5 py-0.5 rounded text-xs">chrome://extensions</code>, activa el <strong>Modo desarrollador</strong> y arrastra el archivo.
          </p>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <div class="w-10 h-10 rounded-xl bg-green-600 text-white flex items-center justify-center font-bold text-lg mb-4">3</div>
          <h3 class="font-bold text-gray-900 mb-2">Activa y a vender</h3>
          <p class="text-sm text-gray-600">Abre la extensión, haz clic en <strong>Activar Premium</strong> y deja que la IA trabaje por ti 24/7.</p>
        </div>
      </div>

      <!-- Botón de descarga -->
      <div class="mt-10">
        <a
          href="/wallabot-1.0.0.crx"
          download
          class="inline-flex items-center px-8 py-4 text-lg font-semibold bg-green-600 text-white rounded-xl hover:bg-green-500 transition-all shadow-lg shadow-green-600/30 no-underline"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mr-2">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Descargar WallaBot
        </a>
        <p class="mt-3 text-sm text-gray-400">Versión 1.0.0 · Chrome 88+ · 42 KB</p>
      </div>

      <!-- Ayuda -->
      <div class="mt-12 p-6 bg-amber-50 border border-amber-100 rounded-xl text-left">
        <h3 class="font-bold text-amber-800 flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
          ¿Necesitas ayuda?
        </h3>
        <p class="mt-2 text-sm text-amber-700">
          Si tienes problemas con la instalación, escríbenos a <a href="mailto:hola@wallabot.pro" class="font-semibold underline">hola@wallabot.pro</a> y te ayudamos en menos de 24h.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
