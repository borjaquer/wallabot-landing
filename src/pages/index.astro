---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import StripeCheckout from '../components/StripeCheckout.astro';
---

<Layout
  title="WallaBot — Automatiza tus ventas en Wallapop con IA"
  description="WallaBot responde automáticamente a tus compradores de Wallapop 24/7. Aumenta tus ventas mientras duermes. 14 días de prueba gratis."
  canonicalURL="https://wallabot.pro"
>
  <Navbar />

  <!-- ============================================================ -->
  <!-- HERO -->
  <!-- ============================================================ -->
  <section class="pt-24 pb-16 sm:pt-32 sm:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Hero Text -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-green-50 border border-green-100 rounded-full text-xs font-medium text-green-700 mb-6">
          <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
          Extensión de Chrome · Sin instalación complicada
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 leading-tight">
          Tu asistente de ventas<br>
          <span class="text-green-600">24/7 en Wallapop</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-600 leading-relaxed max-w-lg">
          WallaBot responde automáticamente a tus compradores mientras duermes,
          trabajas o vives tu vida. Como tener un dependiente que nunca duerme.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/wallabot-1.0.0.crx" download class="inline-flex items-center px-6 py-3 text-base font-semibold bg-green-600 text-white rounded-xl hover:bg-green-500 transition-all shadow-lg shadow-green-600/30 no-underline">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mr-2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Descargar extensión
          </a>
          <a href="#demo" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-gray-700 border border-gray-200 rounded-xl hover:border-gray-300 hover:bg-gray-50 transition-all no-underline">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><polygon points="4,2 14,8 4,14" fill="currentColor"/></svg>
            Ver demo
          </a>
        </div>
        <div class="mt-10 flex gap-8">
          <div>
            <span class="text-2xl font-extrabold text-gray-900">+40%</span>
            <span class="block text-sm text-gray-500 mt-0.5">más ventas</span>
          </div>
          <div>
            <span class="text-2xl font-extrabold text-gray-900">{'<2 min'}</span>
            <span class="block text-sm text-gray-500 mt-0.5">de configuración</span>
          </div>
          <div>
            <span class="text-2xl font-extrabold text-gray-900">24/7</span>
            <span class="block text-sm text-gray-500 mt-0.5">sin descanso</span>
          </div>
        </div>
      </div>
      
      <!-- Chat Animation Mock -->
      <div id="demo" class="lg:flex lg:justify-end">
        <div class="w-full max-w-sm bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden" aria-label="Demo del chat de Wallapop con respuestas automáticas">
          <div class="px-4 py-3 border-b border-gray-100 flex items-center gap-2 bg-gray-50/50">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="8" stroke="#999" stroke-width="2"/><circle cx="9" cy="7" r="2" fill="#999"/><path d="M4 13c1.5-2 4-3 5-3s3.5 1 5 3" stroke="#999" stroke-width="2" stroke-linecap="round"/></svg>
            <span class="text-sm font-medium text-gray-700">María G.</span>
            <span class="text-xs text-green-600 ml-auto font-medium">ahora</span>
          </div>
          <div class="px-4 py-3 h-[300px] overflow-y-auto bg-gray-50/30" id="chatBody">
            <!-- Messages populated by JS -->
          </div>
          <div class="px-4 py-3 border-t border-gray-100 bg-white flex items-center gap-2">
            <span class="text-gray-400 text-sm" id="chatCursor">|</span>
            <span class="text-gray-400 text-sm">Escribe un mensaje...</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- COMO FUNCIONA -->
  <!-- ============================================================ -->
  <section id="como-funciona" class="py-20 sm:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-green-600 uppercase tracking-wider">Así de simple</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-gray-900">Empieza en 3 pasos</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">No necesitas saber de programación. Solo instalar, conectar y dejar que trabaje solo.</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8 items-start">
        <!-- Paso 1 -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-white shadow-md border border-gray-100 text-xl font-extrabold text-green-600 mb-4">1</div>
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gray-900 text-white mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Instala la extensión</h3>
          <p class="text-gray-600 text-sm">Añade WallaBot a Chrome en un clic. Funciona en segundo plano sin molestarte.</p>
        </div>
        
        <!-- Paso 2 -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-white shadow-md border border-gray-100 text-xl font-extrabold text-green-600 mb-4">2</div>
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gray-900 text-white mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Conecta tu catálogo</h3>
          <p class="text-gray-600 text-sm">Sincroniza tus productos de Wallapop. WallaBot aprende qué vendes y a qué precio.</p>
        </div>
        
        <!-- Paso 3 -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-white shadow-md border border-gray-100 text-xl font-extrabold text-green-600 mb-4">3</div>
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gray-900 text-white mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M22 11v1a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Activa y a vender</h3>
          <p class="text-gray-600 text-sm">Pulsa un botón y WallaBot empezará a responder. Tú solo recoges los beneficios.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FEATURES -->
  <!-- ============================================================ -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-green-600 uppercase tracking-wider">Por qué WallaBot</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-gray-900">Ventajas que notarás desde el primer día</h2>
      </div>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-green-600 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">IA con contexto real</h3>
          <p class="text-sm text-gray-600">El bot conoce tu catálogo, tus precios y tu tono. Responde como lo harías tú, con información precisa de cada producto.</p>
        </div>
        
        <div class="p-6 rounded-2xl border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-green-600 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M17 18a2 2 0 100-4 2 2 0 000 4zM7 10a2 2 0 100-4 2 2 0 000 4z"/><path d="M7 8h2.5l1.5 9h2"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Negocia por ti</h3>
          <p class="text-sm text-gray-600">Regatea de forma natural con márgenes que tú defines. Sabe cuándo aceptar, cuándo contraofertar y cuándo decir que no.</p>
        </div>
        
        <div class="p-6 rounded-2xl border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-green-600 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 000 4h4a2 2 0 010 4H8"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Respuesta instantánea</h3>
          <p class="text-sm text-gray-600">El 90% de los compradores compra al primer vendedor que responde. WallaBot contesta en segundos, no en horas.</p>
        </div>
        
        <div class="p-6 rounded-2xl border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-green-600 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Indetectable</h3>
          <p class="text-sm text-gray-600">Funciona como extensión de Chrome, no como bot externo. Wallapop no puede detectarlo. Tus conversaciones parecen 100% humanas.</p>
        </div>
        
        <div class="p-6 rounded-2xl border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-green-600 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Multi-producto</h3>
          <p class="text-sm text-gray-600">Gestiona decenas de artículos a la vez. Cada conversación sabe exactamente de qué producto está hablando.</p>
        </div>
        
        <div class="p-6 rounded-2xl border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-green-600 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Estadísticas en tiempo real</h3>
          <p class="text-sm text-gray-600">Dashboard con conversaciones, ventas cerradas y mensajes respondidos. Mide tu ROI al instante.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- PRECIOS -->
  <!-- ============================================================ -->
  <section id="precios" class="py-20 sm:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-green-600 uppercase tracking-wider">Precios</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-gray-900">Simple y transparente</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">14 días de prueba gratis. Sin compromiso. Cancela cuando quieras.</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <!-- Plan Mensual -->
        <div class="relative bg-white rounded-2xl shadow-xl border-2 border-green-500 p-8 flex flex-col">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-green-500 text-white text-xs font-bold px-4 py-1 rounded-full">Más popular</div>
          <div class="mb-6">
            <h3 class="text-xl font-bold text-gray-900">Premium Mensual</h3>
            <div class="mt-3 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-gray-900">29€</span>
              <span class="text-gray-500">/mes</span>
            </div>
            <p class="mt-2 text-sm text-gray-600">Para vendedores que quieren maximizar sus ventas sin atarse.</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3.5 3.5L13 5"/></svg>
              Respuestas ilimitadas 24/7
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3.5 3.5L13 5"/></svg>
              Hasta 100 productos en catálogo
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3.5 3.5L13 5"/></svg>
              Negociación automática con márgenes
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3.5 3.5L13 5"/></svg>
              Estadísticas de conversaciones
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3.5 3.5L13 5"/></svg>
              Actualizaciones automáticas
            </li>
          </ul>
          <StripeCheckout
            priceId="price_1TYK1S0LtlbFM4VN5mFyL6UK"
            buttonText="Empezar prueba gratis"
            variant="primary"
          />
          <p class="mt-3 text-xs text-center text-gray-400">14 días gratis · Sin permanencia</p>
        </div>
        
        <!-- Plan Anual -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 flex flex-col">
          <div class="mb-6">
            <h3 class="text-xl font-bold text-gray-900">Premium Anual</h3>
            <div class="mt-3 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-gray-900">249€</span>
              <span class="text-gray-500">/año</span>
            </div>
            <p class="mt-2 text-sm text-gray-600">Ahorra un 28%. Para vendedores profesionales que van en serio.</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3.5 3.5L13 5"/></svg>
              Todo lo del plan mensual
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3.5 3.5L13 5"/></svg>
              Productos ilimitados
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3.5 3.5L13 5"/></svg>
              Soporte prioritario 8h
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3.5 3.5L13 5"/></svg>
              2 meses gratis (vs mensual)
            </li>
          </ul>
          <StripeCheckout
            priceId="price_1TYK1S0LtlbFM4VN5mFyL6UK"
            buttonText="Contratar plan anual"
            variant="secondary"
          />
          <p class="mt-3 text-xs text-center text-gray-400">20.75€/mes al pagar anualmente</p>
        </div>
      </div>
      
      <div class="mt-10 flex items-center justify-center gap-2 text-sm text-gray-500">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
        <span>Garantía de devolución de 7 días. Si no estás satisfecho, te devolvemos el dinero.</span>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TESTIMONIALS -->
  <!-- ============================================================ -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-green-600 uppercase tracking-wider">Testimonios</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-gray-900">Lo que dicen nuestros usuarios</h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <blockquote class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <div class="text-yellow-400 text-lg mb-3">★★★★★</div>
          <p class="text-gray-700 text-sm leading-relaxed mb-4">"Vendo muebles restaurados y recibo 20-30 mensajes al día. Desde que tengo WallaBot he pasado de perder la mitad de ventas por no contestar a tiempo a cerrar casi todas. Se paga solo en un día."</p>
          <footer class="border-t border-gray-200 pt-3">
            <strong class="text-sm text-gray-900">Carlos M.</strong>
            <span class="block text-xs text-gray-500">Vendedor de muebles · Barcelona</span>
          </footer>
        </blockquote>
        
        <blockquote class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <div class="text-yellow-400 text-lg mb-3">★★★★★</div>
          <p class="text-gray-700 text-sm leading-relaxed mb-4">"Al principio dudaba de si las respuestas sonarían robóticas. Nada que ver. La IA escribe exactamente como yo, con mis expresiones. Mis clientes no tienen ni idea de que les responde un bot."</p>
          <footer class="border-t border-gray-200 pt-3">
            <strong class="text-sm text-gray-900">Laura P.</strong>
            <span class="block text-xs text-gray-500">Vendedora de ropa · Madrid</span>
          </footer>
        </blockquote>
        
        <blockquote class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <div class="text-yellow-400 text-lg mb-3">★★★★★</div>
          <p class="text-gray-700 text-sm leading-relaxed mb-4">"Lo instalé con miedo de que Wallapop me baneara. Llevo 3 meses usándolo y cero problemas. Es una extensión de Chrome, no un script raro. Indetectable totalmente."</p>
          <footer class="border-t border-gray-200 pt-3">
            <strong class="text-sm text-gray-900">Miguel A.</strong>
            <span class="block text-xs text-gray-500">Tienda de electrónica · Valencia</span>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FAQ -->
  <!-- ============================================================ -->
  <section id="faq" class="py-20 sm:py-28 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-green-600 uppercase tracking-wider">FAQ</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-gray-900">Preguntas frecuentes</h2>
      </div>
      
      <div class="space-y-4">
        <details class="group bg-white rounded-xl border border-gray-100 p-5">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between gap-4 after:content-['+'] after:text-xl after:text-gray-400 group-open:after:content-['−']">
            ¿Es legal usar WallaBot en Wallapop?
          </summary>
          <p class="mt-3 text-sm text-gray-600 leading-relaxed">Sí. WallaBot funciona como una extensión de Chrome que automatiza tu navegador. No vulnera los términos de Wallapop porque ejecuta las acciones como lo harías tú manualmente. Además, al ser una extensión y no un bot externo, es indetectable.</p>
        </details>
        
        <details class="group bg-white rounded-xl border border-gray-100 p-5">
          <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between gap-4 after:content-['+'] after:text-xl after:text-gray-400 group-open:after:content-['−']">
            ¿Necesito tener el ordenador encendido todo el día?
          </summary>
