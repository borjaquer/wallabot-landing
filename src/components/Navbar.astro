---
// Navbar reutilizable con scroll effect
export interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
---

<nav
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all',
    transparent ? 'bg-transparent' : 'bg-white/95 backdrop-blur-sm',
  ]}
  id="nav"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-gray-900 no-underline">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
        <rect width="28" height="28" rx="7" fill="#121212"/>
        <path d="M7 14.5h3.2l1.8-5.5 3.2 10 2.1-4.5H21" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>WallaBot</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a href="/#como-funciona" class="text-sm text-gray-600 hover:text-gray-900 transition-colors no-underline">Cómo funciona</a>
      <a href="/#precios" class="text-sm text-gray-600 hover:text-gray-900 transition-colors no-underline">Precios</a>
      <a href="/faq" class="text-sm text-gray-600 hover:text-gray-900 transition-colors no-underline">FAQ</a>
    </div>

    <div class="flex items-center gap-3">
      <a href="/download" class="hidden sm:inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-700 border border-gray-200 rounded-lg hover:border-gray-300 hover:bg-gray-50 transition-all no-underline">
        Descargar
      </a>
      <a href="/#precios" class="inline-flex items-center px-4 py-2 text-sm font-semibold bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors no-underline">
        Probarlo gratis
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav');
  if (nav) {
    const isTransparent = nav.classList.contains('bg-transparent');
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY > 10;
      if (isTransparent) {
        nav.classList.toggle('bg-white/95', scrolled);
        nav.classList.toggle('backdrop-blur-sm', scrolled);
      }
      nav.classList.toggle('shadow-sm', scrolled);
      nav.classList.toggle('border-b', scrolled);
      nav.classList.toggle('border-gray-100', scrolled);
    });
  }
</script>
